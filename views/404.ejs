<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 | Satyam Singh</title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;text-align:center;padding:25px;">
        <h1 style="color:var(--accent);font-family:var(--font-mono);font-size:clamp(100px,15vw,150px);line-height:1;">404</h1>
        <h2 style="color:var(--lightest-slate);margin-bottom:15px;">Page Not Found</h2>
        <p style="max-width:400px;margin-bottom:30px;">The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="btn">Go Home</a>
    </main>
