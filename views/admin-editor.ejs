<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= blog ? 'Edit' : 'New' %> Post | Blog Admin</title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 40px;
            background: var(--light-navy);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-nav h2 {
            color: var(--lightest-slate);
            font-size: 18px;
        }
        .admin-nav h2 span { color: var(--accent); }
        .admin-nav-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .admin-nav-actions a {
            color: var(--slate);
            font-size: 13px;
            font-family: var(--font-mono);
            text-decoration: none;
            transition: color 0.2s;
        }
        .admin-nav-actions a:hover { color: var(--accent); }

        .editor-page {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 25px 80px;
        }
        .editor-page h1 {
            color: var(--lightest-slate);
            font-size: 28px;
            margin-bottom: 30px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            color: var(--accent);
            font-family: var(--font-mono);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            background: var(--lightest-navy);
            border: 1px solid var(--lightest-navy);
            border-radius: 4px;
            color: var(--lightest-slate);
            font-family: var(--font-sans);
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--accent);
        }
        .form-group textarea {
            font-family: var(--font-mono);
            font-size: 14px;
            line-height: 1.6;
            resize: vertical;
        }
        .form-group select {
            cursor: pointer;
        }
        .form-group select option {
            background: var(--navy);
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .form-hint {
            color: var(--slate);
            font-size: 12px;
            font-family: var(--font-mono);
            margin-top: 6px;
        }

        /* Image upload */
        .image-upload-area {
            display: flex;
            gap: 15px;
            align-items: flex-start;
        }
        .image-upload-area input[type="text"] {
            flex: 1;
        }
        .upload-btn {
            position: relative;
            padding: 12px 20px;
            background: var(--lightest-navy);
            border: 1px dashed var(--slate);
            border-radius: 4px;
            color: var(--slate);
            font-family: var(--font-mono);
            font-size: 13px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s;
        }
        .upload-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }
        .upload-btn input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }
        .cover-preview {
            margin-top: 10px;
            max-height: 200px;
            border-radius: 6px;
            display: none;
        }
        .cover-preview.show {
            display: block;
        }

        /* Inline image insert for content */
        .toolbar {
            display: flex;
            gap: 8px;
            margin-bottom: 8px;
        }
        .toolbar button {
            background: var(--lightest-navy);
            border: none;
            color: var(--slate);
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            font-family: var(--font-mono);
            transition: all 0.2s;
        }
        .toolbar button:hover {
            color: var(--accent);
            background: rgba(100, 255, 218, 0.1);
        }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }
        .btn-secondary {
            padding: 12px 24px;
            background: transparent;
            border: 1px solid var(--slate);
            color: var(--slate);
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-secondary:hover {
            border-color: var(--accent);
            color: var(--accent);
        }
        .uploading-indicator {
            display: none;
            align-items: center;
            gap: 8px;
            color: var(--accent);
            font-family: var(--font-mono);
            font-size: 13px;
            margin-top: 8px;
        }
        .uploading-indicator.show { display: flex; }

        /* Preview panel */
        .preview-panel {
            display: none;
            background: var(--navy);
            border: 1px solid var(--lightest-navy);
            border-radius: 6px;
            padding: 30px;
            margin-top: 12px;
            max-height: 600px;
            overflow-y: auto;
            line-height: 1.8;
            font-size: 16px;
        }
        .preview-panel.show { display: block; }
        .preview-panel h2 {
            color: var(--lightest-slate);
            font-size: 22px;
            margin: 40px 0 15px;
        }
        .preview-panel h2:first-child { margin-top: 0; }
        .preview-panel h3 {
            color: var(--lightest-slate);
            font-size: 20px;
            margin: 30px 0 10px;
        }
        .preview-panel p {
            margin-bottom: 15px;
            color: var(--slate);
        }
        .preview-panel strong {
            color: var(--lightest-slate);
        }
        .preview-panel em {
            color: var(--light-slate);
            font-style: italic;
        }
        .preview-panel ul, .preview-panel ol {
            padding-left: 25px;
            margin-bottom: 15px;
        }
        .preview-panel ol { list-style: decimal; }
        .preview-panel li {
            margin-bottom: 8px;
            color: var(--slate);
        }
        .preview-panel pre {
            background: var(--light-navy);
            border: 1px solid var(--lightest-navy);
            border-radius: 4px;
            padding: 20px;
            overflow-x: auto;
            margin: 20px 0;
            font-family: var(--font-mono);
            font-size: 14px;
            line-height: 1.6;
        }
        .preview-panel code {
            font-family: var(--font-mono);
            font-size: 14px;
            color: var(--accent);
        }
        .preview-panel pre code {
            color: var(--light-slate);
        }
        .preview-panel blockquote {
            border-left: 3px solid var(--accent);
            padding: 16px 20px;
            margin: 20px 0;
            background: rgba(100, 255, 218, 0.03);
            border-radius: 0 6px 6px 0;
            color: var(--light-slate);
            font-style: italic;
        }
        .preview-panel hr {
            border: none;
            height: 1px;
            background: var(--lightest-navy);
            margin: 35px 0;
        }
        .preview-panel a {
            color: var(--accent);
        }
        .preview-panel img {
            max-width: 100%;
            border-radius: 6px;
            margin: 20px 0;
        }
        .preview-panel table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            font-size: 14px;
        }
        .preview-panel th {
            text-align: left;
            padding: 10px 16px;
            font-family: var(--font-mono);
            font-size: 12px;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--lightest-navy);
        }
        .preview-panel td {
            padding: 10px 16px;
            color: var(--light-slate);
            border-bottom: 1px solid rgba(100, 255, 218, 0.05);
        }
        .toolbar-right {
            margin-left: auto;
            display: flex;
            gap: 8px;
        }
        .toolbar-right button {
            background: var(--lightest-navy);
            border: none;
            color: var(--slate);
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            font-family: var(--font-mono);
            transition: all 0.2s;
        }
        .toolbar-right button:hover {
            color: var(--accent);
            background: rgba(100, 255, 218, 0.1);
        }
        .toolbar-right button.active {
            color: var(--accent);
            background: rgba(100, 255, 218, 0.15);
            border: 1px solid rgba(100, 255, 218, 0.3);
        }
        .toolbar {
            flex-wrap: wrap;
        }
        .spinner {
            width: 14px; height: 14px;
            border: 2px solid var(--lightest-navy);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .form-row { grid-template-columns: 1fr; }
            .admin-nav { padding: 12px 20px; }
            .editor-page { padding: 25px 15px 60px; }
            .image-upload-area { flex-direction: column; }
        }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <h2><span>&lt;</span>Admin<span>/&gt;</span></h2>
        <div class="admin-nav-actions">
            <a href="/admin">Dashboard</a>
            <a href="/">View Site</a>
            <a href="/admin/logout">Logout</a>
        </div>
    </nav>

    <div class="editor-page">
        <h1><%= blog ? 'Edit Post' : 'New Post' %></h1>
        <form method="POST" action="<%= blog ? '/admin/update/' + blog.id : '/admin/create' %>" id="editorForm">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" id="titleInput" value="<%= blog ? blog.title : '' %>" placeholder="Your blog post title" required maxlength="100">
                <div class="form-hint"><span id="titleCharCount"><%= blog ? blog.title.length : 0 %></span> / 100 characters</div>
            </div>

            <div class="form-group">
                <label>Excerpt</label>
                <input type="text" name="excerpt" value="<%= blog ? blog.excerpt : '' %>" placeholder="A brief summary of the post" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Category</label>
                    <select name="category">
                        <option value="tech" <%= (blog && blog.category === 'tech') ? 'selected' : '' %>>Tech</option>
                        <option value="daily" <%= (blog && blog.category === 'daily') ? 'selected' : '' %>>Daily Update</option>
                        <option value="life" <%= (blog && blog.category === 'life') ? 'selected' : '' %>>Life</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Tags</label>
                    <input type="text" name="tags" value="<%= blog ? blog.tags.join(', ') : '' %>" placeholder="e.g. javascript, react, webdev">
                    <div class="form-hint">Comma-separated</div>
                </div>
            </div>

            <div class="form-group">
                <label>Cover Image</label>
                <div class="image-upload-area">
                    <input type="text" name="coverImage" id="coverImageUrl" value="<%= blog && blog.coverImage ? blog.coverImage : '' %>" placeholder="Image URL or upload one">
                    <label class="upload-btn">
                        <i class="fas fa-cloud-upload-alt"></i> Upload
                        <input type="file" id="coverImageFile" accept="image/*">
                    </label>
                </div>
                <div class="uploading-indicator" id="coverUploadStatus">
                    <div class="spinner"></div>
                    <span>Uploading...</span>
                </div>
                <img class="cover-preview <%= (blog && blog.coverImage) ? 'show' : '' %>" id="coverPreview"
                     src="<%= (blog && blog.coverImage) ? blog.coverImage : '' %>" alt="">
            </div>

            <div class="form-group">
                <label>Content</label>
                <div class="toolbar">
                    <button type="button" onclick="insertMd('**', '**')" title="Bold"><i class="fas fa-bold"></i></button>
                    <button type="button" onclick="insertMd('*', '*')" title="Italic"><i class="fas fa-italic"></i></button>
                    <button type="button" onclick="insertMd('## ', '')" title="Heading"><i class="fas fa-heading"></i></button>
                    <button type="button" onclick="insertMd('`', '`')" title="Code"><i class="fas fa-code"></i></button>
                    <button type="button" onclick="insertMd('\n```\n', '\n```\n')" title="Code Block"><i class="fas fa-file-code"></i></button>
                    <button type="button" onclick="insertMd('[', '](url)')" title="Link"><i class="fas fa-link"></i></button>
                    <button type="button" id="insertImageBtn" title="Insert Image"><i class="fas fa-image"></i></button>
                    <button type="button" onclick="insertMd('\n- ', '')" title="List"><i class="fas fa-list-ul"></i></button>
                    <button type="button" onclick="insertMd('\n> ', '')" title="Quote"><i class="fas fa-quote-left"></i></button>
                    <button type="button" onclick="insertMd('\n\n', '')" title="Blank Line"><i class="fas fa-arrows-alt-v"></i></button>
                    <button type="button" onclick="insertMd('\n---\n', '')" title="Horizontal Rule"><i class="fas fa-minus"></i></button>
                    <div class="toolbar-right">
                        <button type="button" id="previewToggle" title="Preview"><i class="fas fa-eye"></i> Preview</button>
                        <button type="button" id="templateBtn" title="Insert Template"><i class="fas fa-file-alt"></i> Template</button>
                    </div>
                </div>
                <textarea name="content" id="contentArea" rows="20" placeholder="Write your content in Markdown..." required><%= blog ? blog.content : '' %></textarea>
                <div id="previewPanel" class="preview-panel"></div>
                <div class="form-hint">Supports Markdown: **bold**, *italic*, ## headings, ```code blocks```, [links](url), ![images](url), > blockquotes, --- horizontal rules</div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn"><%= blog ? 'Update Post' : 'Publish Post' %></button>
                <a href="/admin" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <script>
        const contentArea = document.getElementById('contentArea');
        const coverImageFile = document.getElementById('coverImageFile');
        const coverImageUrl = document.getElementById('coverImageUrl');
        const coverPreview = document.getElementById('coverPreview');
        const coverUploadStatus = document.getElementById('coverUploadStatus');

        function insertMd(before, after) {
            const start = contentArea.selectionStart;
            const end = contentArea.selectionEnd;
            const selected = contentArea.value.substring(start, end);
            const text = before + (selected || 'text') + after;
            contentArea.setRangeText(text, start, end, 'select');
            contentArea.focus();
        }

        // Cover image upload
        coverImageFile.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('image', file);
            coverUploadStatus.classList.add('show');
            try {
                const res = await fetch('/admin/upload-image', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.url) {
                    coverImageUrl.value = data.url;
                    coverPreview.src = data.url;
                    coverPreview.classList.add('show');
                } else {
                    alert(data.error || 'Upload failed');
                }
            } catch (err) {
                alert('Upload failed: ' + err.message);
            }
            coverUploadStatus.classList.remove('show');
        });

        // Preview cover image from URL
        coverImageUrl.addEventListener('input', () => {
            const url = coverImageUrl.value.trim();
            if (url) {
                coverPreview.src = url;
                coverPreview.classList.add('show');
            } else {
                coverPreview.classList.remove('show');
            }
        });

        // Insert inline image
        document.getElementById('insertImageBtn').addEventListener('click', () => {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                const formData = new FormData();
                formData.append('image', file);
                const btn = document.getElementById('insertImageBtn');
                btn.innerHTML = '<div class="spinner" style="width:12px;height:12px;display:inline-block;"></div>';
                try {
                    const res = await fetch('/admin/upload-image', { method: 'POST', body: formData });
                    const data = await res.json();
                    if (data.url) {
                        insertMd('![', '](' + data.url + ')');
                    } else {
                        alert(data.error || 'Upload failed');
                    }
                } catch (err) {
                    alert('Upload failed: ' + err.message);
                }
                btn.innerHTML = '<i class="fas fa-image"></i>';
            };
            input.click();
        });

        // --- Markdown Preview ---
        const previewPanel = document.getElementById('previewPanel');
        const previewToggle = document.getElementById('previewToggle');
        let previewActive = false;

        function renderPreviewMarkdown(md) {
            let s = md.replace(/\r\n/g, '\n');
            // code blocks first
            const codeBlocks = [];
            s = s.replace(/```(\w+)?\n([\s\S]*?)```/g, function(match, lang, code) {
                const idx = codeBlocks.length;
                codeBlocks.push('<pre><code>' + code.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</code></pre>');
                return '\n%%CODEBLOCK_' + idx + '%%\n';
            });
            // horizontal rules
            s = s.replace(/\n---\n/g, '\n<hr>\n');
            // headings
            s = s.replace(/\n### (.*)/g, '<h3>$1</h3>');
            s = s.replace(/\n## (.*)/g, '<h2>$1</h2>');
            // blockquotes
            s = s.replace(/(?:^|\n)(?:> (.*)(?:\n|$))+/g, function(block) {
                const lines = block.trim().split('\n').map(l => l.replace(/^>\s?/, ''));
                return '<blockquote>' + lines.join('<br>') + '</blockquote>';
            });
            // tables
            s = s.replace(/(\n\|.+\|(?:\n\|.+\|)+)/g, function(tableBlock) {
                const rows = tableBlock.trim().split('\n').filter(r => r.trim());
                if (rows.length < 2) return tableBlock;
                let html = '<table>';
                const hCells = rows[0].split('|').filter(c => c.trim() !== '');
                html += '<thead><tr>';
                hCells.forEach(c => { html += '<th>' + c.trim() + '</th>'; });
                html += '</tr></thead><tbody>';
                for (let i = 2; i < rows.length; i++) {
                    const cells = rows[i].split('|').filter(c => c.trim() !== '');
                    html += '<tr>';
                    cells.forEach(c => { html += '<td>' + c.trim() + '</td>'; });
                    html += '</tr>';
                }
                html += '</tbody></table>';
                return html;
            });
            // images
            s = s.replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1">');
            // links
            s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>');
            // bold
            s = s.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            // italic
            s = s.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
            // inline code
            s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
            // unordered lists
            s = s.replace(/((?:^|\n)- .*(?:\n- .*)*)/g, function(block) {
                const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^- /, '') + '</li>');
                return '<ul>' + items.join('') + '</ul>';
            });
            // ordered lists
            s = s.replace(/((?:^|\n)\d+\. .*(?:\n\d+\. .*)*)/g, function(block) {
                const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^\d+\.\s/, '') + '</li>');
                return '<ol>' + items.join('') + '</ol>';
            });
            // paragraphs
            s = s.replace(/\n\n/g, '</p><p>');
            s = '<p>' + s + '</p>';
            // cleanup
            s = s.replace(/<p>\s*<\/p>/g, '');
            s = s.replace(/<p>\s*(<h[23]>)/g, '$1');
            s = s.replace(/(<\/h[23]>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<ul>)/g, '$1');
            s = s.replace(/(<\/ul>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<ol>)/g, '$1');
            s = s.replace(/(<\/ol>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<blockquote)/g, '$1');
            s = s.replace(/(<\/blockquote>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<pre>)/g, '$1');
            s = s.replace(/(<\/pre>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<hr[^>]*>)\s*<\/p>/g, '$1');
            s = s.replace(/<p>\s*(<table)/g, '$1');
            s = s.replace(/(<\/table>)\s*<\/p>/g, '$1');
            // restore code blocks
            for (let i = 0; i < codeBlocks.length; i++) {
                s = s.replace('%%CODEBLOCK_' + i + '%%', codeBlocks[i]);
            }
            return s;
        }

        previewToggle.addEventListener('click', () => {
            previewActive = !previewActive;
            previewToggle.classList.toggle('active', previewActive);
            if (previewActive) {
                previewPanel.innerHTML = renderPreviewMarkdown(contentArea.value);
                previewPanel.classList.add('show');
                contentArea.style.display = 'none';
            } else {
                previewPanel.classList.remove('show');
                contentArea.style.display = '';
            }
        });

        // --- Default Blog Template ---
        const templateBtn = document.getElementById('templateBtn');
        const blogTemplate = `Write a compelling opening paragraph that hooks the reader. Explain what problem this post addresses and why it matters.

## The Problem

Describe the challenge or problem clearly. What pain points does your audience face? Why do existing solutions fall short?

## The Approach

Explain your solution or approach step by step. Use subheadings to break down complex ideas.

### Key Concept 1

Explain the first major concept. Use examples and analogies to make it accessible.

### Key Concept 2

Explain the second major concept. Reference real-world scenarios where applicable.

## Implementation

Walk through the technical implementation. Include code snippets where relevant:

\`\`\`java
// Your code example here
public class Example {
    public void demonstrate() {
        // Implementation details
    }
}
\`\`\`

## Results and Impact

Share measurable outcomes, performance improvements, or lessons from production. Use concrete numbers when possible.

## Key Takeaways

- First key insight the reader should remember
- Second key insight with practical application
- Third key insight or recommendation

> A memorable closing thought or quote that reinforces your main message.`;

        templateBtn.addEventListener('click', () => {
            if (contentArea.value.trim().length > 0) {
                if (!confirm('This will replace your current content with a template. Continue?')) return;
            }
            contentArea.value = blogTemplate;
            contentArea.focus();
            if (previewActive) {
                previewPanel.innerHTML = renderPreviewMarkdown(contentArea.value);
            }
        });

        // --- Title character counter ---
        const titleInput = document.getElementById('titleInput');
        const titleCharCount = document.getElementById('titleCharCount');
        titleInput.addEventListener('input', () => {
            titleCharCount.textContent = titleInput.value.length;
        });
    </script>
</body>
</html>
