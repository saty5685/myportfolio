<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visitors | Admin</title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 40px;
            background: var(--light-navy);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-nav h2 { color: var(--lightest-slate); font-size: 18px; }
        .admin-nav h2 span { color: var(--accent); }
        .admin-nav-actions { display: flex; gap: 12px; align-items: center; }
        .admin-nav-actions a {
            color: var(--slate);
            font-size: 13px;
            font-family: var(--font-mono);
            text-decoration: none;
            transition: color 0.2s;
        }
        .admin-nav-actions a:hover { color: var(--accent); }

        .admin-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 25px;
        }
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }
        .admin-header h1 { color: var(--lightest-slate); font-size: 28px; }
        .header-actions { display: flex; gap: 10px; align-items: center; }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 35px;
        }
        .stat-card {
            background: var(--light-navy);
            border-radius: 8px;
            padding: 24px;
            border: 1px solid rgba(100, 255, 218, 0.05);
        }
        .stat-card .stat-label {
            font-family: var(--font-mono);
            font-size: 11px;
            color: var(--slate);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .stat-card .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--accent);
        }
        .stat-card .stat-sub {
            font-size: 12px;
            color: var(--slate);
            margin-top: 4px;
        }

        /* Visitor Table */
        .visitor-table {
            width: 100%;
            border-collapse: collapse;
        }
        .visitor-table th {
            text-align: left;
            padding: 12px 16px;
            font-family: var(--font-mono);
            font-size: 11px;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--lightest-navy);
        }
        .visitor-table td {
            padding: 12px 16px;
            color: var(--slate);
            font-size: 13px;
            border-bottom: 1px solid rgba(100, 255, 218, 0.05);
            max-width: 250px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .visitor-table tr:hover td {
            background: rgba(100, 255, 218, 0.02);
        }
        .visitor-id {
            font-family: var(--font-mono);
            color: var(--lightest-slate);
            font-size: 12px;
        }
        .visit-count {
            display: inline-block;
            background: rgba(100, 255, 218, 0.1);
            color: var(--accent);
            padding: 2px 10px;
            border-radius: 12px;
            font-family: var(--font-mono);
            font-size: 12px;
            font-weight: 600;
        }
        .pages-list {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }
        .page-tag {
            background: rgba(100, 255, 218, 0.06);
            color: var(--light-slate);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-family: var(--font-mono);
        }
        .ip-cell {
            font-family: var(--font-mono);
            font-size: 12px;
        }
        .btn-danger {
            background: rgba(255, 107, 107, 0.1);
            color: #ff6b6b;
            border: 1px solid rgba(255, 107, 107, 0.2);
            padding: 8px 16px;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-danger:hover {
            background: rgba(255, 107, 107, 0.2);
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--slate);
        }
        .empty-state i {
            font-size: 48px;
            color: var(--lightest-navy);
            margin-bottom: 16px;
        }

        /* Expandable row */
        .expand-btn {
            background: none;
            border: none;
            color: var(--slate);
            cursor: pointer;
            font-size: 12px;
            padding: 2px 6px;
            border-radius: 4px;
            transition: all 0.2s;
        }
        .expand-btn:hover { color: var(--accent); background: rgba(100,255,218,0.1); }
        .detail-row td {
            padding: 0 16px;
            background: rgba(100, 255, 218, 0.01);
        }
        .detail-content {
            padding: 12px 0;
            font-size: 12px;
            color: var(--light-slate);
        }
        .detail-content .ua-text {
            font-family: var(--font-mono);
            font-size: 11px;
            word-break: break-all;
            color: var(--slate);
        }

        @media (max-width: 768px) {
            .admin-nav { padding: 12px 20px; }
            .admin-content { padding: 25px 15px; }
            .admin-header { flex-direction: column; align-items: flex-start; }
            .visitor-table th:nth-child(4),
            .visitor-table td:nth-child(4),
            .visitor-table th:nth-child(5),
            .visitor-table td:nth-child(5) { display: none; }
        }
    </style>
</head>
<body>
    <nav class="admin-nav">
        <h2><span>&lt;</span>Admin<span>/&gt;</span></h2>
        <div class="admin-nav-actions">
            <a href="/admin">Dashboard</a>
            <a href="/">View Site</a>
            <a href="/admin/logout">Logout</a>
        </div>
    </nav>

    <%
        const totalVisitors = visitors.length;
        const totalPageViews = visitors.reduce((sum, v) => sum + v.visitCount, 0);
        const todayStr = new Date().toISOString().split('T')[0];
        const todayVisitors = visitors.filter(v => v.lastVisit && v.lastVisit.startsWith(todayStr)).length;
        const sorted = visitors.sort((a, b) => new Date(b.lastVisit) - new Date(a.lastVisit));
    %>

    <div class="admin-content">
        <div class="admin-header">
            <h1><i class="fas fa-chart-line"></i> Visitor Analytics</h1>
            <div class="header-actions">
                <a href="/admin" class="btn"><i class="fas fa-arrow-left"></i> Back</a>
                <form method="POST" action="/admin/visitors/clear" onsubmit="return confirm('Clear all visitor data? This cannot be undone.')" style="display:inline;">
                    <button type="submit" class="btn-danger"><i class="fas fa-trash-alt"></i> Clear Data</button>
                </form>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Unique Visitors</div>
                <div class="stat-value"><%= totalVisitors %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Page Views</div>
                <div class="stat-value"><%= totalPageViews %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Today's Visitors</div>
                <div class="stat-value"><%= todayVisitors %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Avg Views / Visitor</div>
                <div class="stat-value"><%= totalVisitors ? (totalPageViews / totalVisitors).toFixed(1) : 0 %></div>
            </div>
        </div>

        <% if (sorted.length === 0) { %>
        <div class="empty-state">
            <i class="fas fa-user-slash"></i>
            <p>No visitors tracked yet.</p>
        </div>
        <% } else { %>
        <table class="visitor-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Visitor ID</th>
                    <th>IP Address</th>
                    <th>Visits</th>
                    <th>Pages</th>
                    <th>First Visit</th>
                    <th>Last Visit</th>
                </tr>
            </thead>
            <tbody>
                <% sorted.forEach((v, i) => { %>
                <tr>
                    <td>
                        <button class="expand-btn" onclick="toggleDetail(<%= i %>)" title="Details">
                            <i class="fas fa-chevron-right" id="icon-<%= i %>"></i>
                        </button>
                    </td>
                    <td class="visitor-id" title="<%= v.visitorId %>"><%= v.visitorId %></td>
                    <td class="ip-cell"><%= v.ip %></td>
                    <td><span class="visit-count"><%= v.visitCount %></span></td>
                    <td>
                        <div class="pages-list">
                            <% (v.pagesVisited || []).slice(0, 4).forEach(p => { %>
                                <span class="page-tag"><%= p %></span>
                            <% }) %>
                            <% if ((v.pagesVisited || []).length > 4) { %>
                                <span class="page-tag">+<%= v.pagesVisited.length - 4 %> more</span>
                            <% } %>
                        </div>
                    </td>
                    <td><%= new Date(v.firstVisit).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                    <td><%= new Date(v.lastVisit).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
                </tr>
                <tr class="detail-row" id="detail-<%= i %>" style="display:none;">
                    <td colspan="7">
                        <div class="detail-content">
                            <strong>User Agent:</strong>
                            <div class="ua-text"><%= v.userAgent %></div>
                            <br>
                            <strong>All Pages Visited:</strong>
                            <div class="pages-list" style="margin-top:6px;">
                                <% (v.pagesVisited || []).forEach(p => { %>
                                    <span class="page-tag"><%= p %> (<%= (v.pageHits && v.pageHits[p]) || '?' %>)</span>
                                <% }) %>
                            </div>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>

    <script>
        function toggleDetail(idx) {
            const row = document.getElementById('detail-' + idx);
            const icon = document.getElementById('icon-' + idx);
            if (row.style.display === 'none') {
                row.style.display = '';
                icon.classList.replace('fa-chevron-right', 'fa-chevron-down');
            } else {
                row.style.display = 'none';
                icon.classList.replace('fa-chevron-down', 'fa-chevron-right');
            }
        }
    </script>
</body>
</html>
