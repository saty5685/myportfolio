<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= blog.title %> | Satyam Singh</title>
    <meta name="description" content="<%= blog.excerpt %>">
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header id="header" class="scrolled">
        <nav>
            <a href="/" class="logo" aria-label="Home"><img src="/images/favicon.svg" alt="SS" class="logo-icon"></a>
            <div class="nav-links" id="navLinks">
                <ol>
                    <li><a href="/#about" class="nav-link">About</a></li>
                    <li><a href="/#experience" class="nav-link">Experience</a></li>
                    <li><a href="/#projects" class="nav-link">Projects</a></li>
                    <li><a href="/blogs" class="nav-link">Blog</a></li>
                    <li><a href="/#contact" class="nav-link">Contact</a></li>
                </ol>
                <a href="/docs/SatyamSinghResume.pdf" class="btn btn-sm" download>Resume</a>
            </div>
            <button class="hamburger" id="hamburger" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
    </header>

    <div class="mobile-menu" id="mobileMenu">
        <nav>
            <ol>
                <li><a href="/#about" class="mobile-link">About</a></li>
                <li><a href="/#experience" class="mobile-link">Experience</a></li>
                <li><a href="/#projects" class="mobile-link">Projects</a></li>
                <li><a href="/blogs" class="mobile-link">Blog</a></li>
                <li><a href="/#contact" class="mobile-link">Contact</a></li>
            </ol>
            <a href="/docs/SatyamSinghResume.pdf" class="btn" download>Resume</a>
        </nav>
    </div>

    <main class="blog-page">
        <article class="blog-article">
            <a href="/blogs" class="blog-back"><i class="fas fa-arrow-left"></i> All posts</a>
            <header class="blog-header">
                <!-- <% if (blog.category) { %>
                <span class="blog-category-badge <%= blog.category %>"><%= blog.category %></span>
                <% } %> -->
                <h1><%= blog.title %></h1>
                
            </header>
            <div class="blog-meta">
                    <span><i class="fas fa-calendar-alt"></i> <%= new Date(blog.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    <span><i class="fas fa-clock"></i> <%= blog.readTime %> min read</span>
                </div>
            <% if (blog.coverImage) { %>
            <img class="blog-cover-image" src="<%= blog.coverImage %>" alt="<%= blog.title %>">
            <% } %>
            <div class="blog-body">
                <%
                function renderMarkdown(md) {
                    var s = md.replace(/\r\n/g, '\n');
                    // code blocks first (preserve content)
                    var codeBlocks = [];
                    s = s.replace(/```(\w+)?\n([\s\S]*?)```/g, function(match, lang, code) {
                        var idx = codeBlocks.length;
                        codeBlocks.push('<pre><code class="lang-' + (lang || '') + '">' + code.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</code></pre>');
                        return '\n%%CODEBLOCK_' + idx + '%%\n';
                    });
                    // horizontal rules
                    s = s.replace(/\n---\n/g, '\n<hr class="blog-hr">\n');
                    // headings
                    s = s.replace(/\n### (.*)/g, '<h3>$1</h3>');
                    s = s.replace(/\n## (.*)/g, '<h2>$1</h2>');
                    // blockquotes
                    s = s.replace(/(?:^|\n)(?:> (.*)(?:\n|$))+/g, function(block) {
                        var lines = block.trim().split('\n').map(function(l) { return l.replace(/^>\s?/, ''); });
                        return '<blockquote class="blog-blockquote">' + lines.join('<br>') + '</blockquote>';
                    });
                    // markdown tables
                    s = s.replace(/(\n\|.+\|(?:\n\|.+\|)+)/g, function(tableBlock) {
                        var rows = tableBlock.trim().split('\n').filter(function(r) { return r.trim(); });
                        if (rows.length < 2) return tableBlock;
                        var html = '<table class="blog-table">';
                        var hCells = rows[0].split('|').filter(function(c) { return c.trim() !== ''; });
                        html += '<thead><tr>';
                        hCells.forEach(function(c) { html += '<th>' + c.trim() + '</th>'; });
                        html += '</tr></thead><tbody>';
                        for (var i = 2; i < rows.length; i++) {
                            var cells = rows[i].split('|').filter(function(c) { return c.trim() !== ''; });
                            html += '<tr>';
                            cells.forEach(function(c) { html += '<td>' + c.trim() + '</td>'; });
                            html += '</tr>';
                        }
                        html += '</tbody></table>';
                        return html;
                    });
                    // images
                    s = s.replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1" class="blog-inline-image">');
                    // links
                    s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
                    // bold
                    s = s.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                    // italic (single asterisk, not inside bold)
                    s = s.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
                    // inline code
                    s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
                    // unordered lists
                    s = s.replace(/((?:^|\n)- .*(?:\n- .*)*)/g, function(block) {
                        var items = block.trim().split('\n').map(function(l) {
                            return '<li>' + l.replace(/^- /, '') + '</li>';
                        });
                        return '<ul>' + items.join('') + '</ul>';
                    });
                    // ordered lists
                    s = s.replace(/((?:^|\n)\d+\. .*(?:\n\d+\. .*)*)/g, function(block) {
                        var items = block.trim().split('\n').map(function(l) {
                            return '<li>' + l.replace(/^\d+\.\s/, '') + '</li>';
                        });
                        return '<ol>' + items.join('') + '</ol>';
                    });
                    // paragraphs
                    s = s.replace(/\n\n/g, '</p><p>');
                    s = '<p>' + s + '</p>';
                    // clean up empty paragraphs
                    s = s.replace(/<p>\s*<\/p>/g, '');
                    s = s.replace(/<p>\s*(<h[23]>)/g, '$1');
                    s = s.replace(/(<\/h[23]>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<ul>)/g, '$1');
                    s = s.replace(/(<\/ul>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<ol>)/g, '$1');
                    s = s.replace(/(<\/ol>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<blockquote)/g, '$1');
                    s = s.replace(/(<\/blockquote>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<pre>)/g, '$1');
                    s = s.replace(/(<\/pre>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<hr[^>]*>)\s*<\/p>/g, '$1');
                    s = s.replace(/<p>\s*(<table)/g, '$1');
                    s = s.replace(/(<\/table>)\s*<\/p>/g, '$1');
                    // restore code blocks
                    for (var i = 0; i < codeBlocks.length; i++) {
                        s = s.replace('%%CODEBLOCK_' + i + '%%', codeBlocks[i]);
                    }
                    return s;
                }
                %>
                <%- renderMarkdown(blog.content) %>
            </div>
            <div class="blog-tags-row blog-tags-bottom">
                <% blog.tags.forEach(function(tag) { %>
                <span class="skill-tag"><%= tag %></span>
                <% }); %>
            </div>
        </article>

        <% const otherPosts = blogs.filter(b => b.id !== blog.id).slice(0, 2); %>
        <% if (otherPosts.length > 0) { %>
        <section class="blog-more">
            <h3>More Posts</h3>
            <div class="blog-grid">
                <% otherPosts.forEach(function(post) { %>
                <a href="/blog/<%= post.id %>" class="blog-card">
                    <div class="blog-card-inner">
                        <div class="blog-card-top">
                            <i class="fas fa-newspaper blog-card-icon"></i>
                            <span class="blog-card-date"><%= new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                        </div>
                        <h4><%= post.title %></h4>
                        <p><%= post.excerpt %></p>
                        <div class="blog-card-footer">
                            <ul class="blog-tags">
                                <% post.tags.forEach(function(tag) { %>
                                <li><%= tag %></li>
                                <% }); %>
                            </ul>
                            <span class="blog-read-time"><%= post.readTime %> min read</span>
                        </div>
                    </div>
                </a>
                <% }); %>
            </div>
        </section>
        <% } %>
    </main>

    <footer>
        <div class="footer-socials" style="display:flex;">
            <a href="https://github.com/saty5685" target="_blank" rel="noopener noreferrer" aria-label="GitHub"><i class="fab fa-github"></i></a>
            <a href="https://www.linkedin.com/in/saty5685/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
            <a href="https://leetcode.com/saty5685" target="_blank" rel="noopener noreferrer" aria-label="LeetCode"><i class="fas fa-code"></i></a>
        </div>
        <p>Designed &amp; Built by Satyam Singh</p>
        <p class="footer-note">&copy; 2026 All rights reserved.</p>
    </footer>

    <script src="/utility/script.js"></script>
</body>
</html>
