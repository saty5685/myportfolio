<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Wallet HLD — Interactive Architecture | Satyam Singh</title>
    <meta name="description" content="Interactive High-Level Design diagram of a Digital Wallet Platform — explore 4 scenarios across 8 microservices with step-by-step flow animations.">
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #05080f;
            --surface: #090d16;
            --card: #0d1420;
            --border: #162030;
            --text: #dde6f0;
            --muted: #3d5470;
            --sub: #7a9ab8;
            --client: #06b6d4;
            --gateway: #a855f7;
            --user: #3b82f6;
            --wallet: #22c55e;
            --txn: #f59e0b;
            --payment: #f97316;
            --fraud: #ef4444;
            --kyc: #ec4899;
            --notif: #8b5cf6;
            --ledger: #14b8a6;
            --kafka: #fb923c;
            --db: #64748b;
            --ext: #94a3b8;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'JetBrains Mono', monospace;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* Back link */
        .back-link {
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 100;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--sub);
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 8px;
            background: var(--card);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }
        .back-link:hover {
            color: var(--client);
            border-color: var(--client);
        }
        .back-link svg { width: 14px; height: 14px; }

        .hld-container {
            padding: 20px 16px;
            user-select: none;
            max-width: 1260px;
            margin: 0 auto;
        }

        /* Header */
        .hld-header { text-align: center; margin-bottom: 18px; padding-top: 10px; }
        .hld-title {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 2px;
            color: var(--text);
        }
        .hld-subtitle {
            color: var(--muted);
            font-size: 10px;
            letter-spacing: 3px;
            margin-top: 4px;
        }

        /* Scenario tabs */
        .scenario-tabs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }
        .scenario-tab {
            background: var(--card);
            border: 1.5px solid var(--border);
            color: var(--muted);
            border-radius: 8px;
            padding: 7px 18px;
            cursor: pointer;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            font-family: inherit;
            transition: all 0.2s;
        }
        .scenario-tab:hover { opacity: 0.85; }
        .scenario-tab.active { box-shadow: 0 0 14px rgba(0,0,0,0.3); }

        /* Main layout */
        .hld-main {
            display: flex;
            gap: 14px;
            align-items: flex-start;
        }

        /* SVG canvas */
        .svg-wrap {
            flex: 1;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            min-width: 0;
        }
        .svg-wrap svg { width: 100%; display: block; }

        /* Right panel */
        .right-panel {
            width: 260px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .panel-card {
            background: var(--card);
            border-radius: 10px;
            padding: 12px 14px;
        }
        .flow-title-card { border: 1px solid rgba(0,0,0,0.3); }
        .flow-title-card .flow-name {
            font-weight: 800;
            font-size: 12px;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .flow-title-card .flow-info {
            color: var(--muted);
            font-size: 10px;
        }
        .progress-bar-track {
            height: 4px;
            background: var(--border);
            border-radius: 4px;
            margin-top: 10px;
            overflow: hidden;
        }
        .progress-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s;
        }

        /* Controls */
        .controls { display: flex; gap: 8px; }
        .ctrl-btn {
            flex: 1;
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--sub);
            border-radius: 8px;
            padding: 8px;
            cursor: pointer;
            font-size: 11px;
            font-family: inherit;
            font-weight: 700;
            transition: all 0.2s;
        }
        .ctrl-btn:disabled { color: var(--muted); cursor: default; }
        .play-btn {
            border-radius: 8px;
            padding: 9px;
            cursor: pointer;
            font-size: 11px;
            font-family: inherit;
            font-weight: 800;
            letter-spacing: 1px;
            width: 100%;
            transition: all 0.2s;
        }

        /* Step detail */
        .step-detail-card { padding: 14px; }
        .step-badges { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
        .step-type-badge {
            border-radius: 4px;
            padding: 2px 8px;
            font-size: 9px;
            font-weight: 800;
        }
        .step-num { color: var(--muted); font-size: 9px; }
        .step-nodes {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        .step-node-badge {
            border-radius: 4px;
            padding: 2px 7px;
            font-size: 9px;
            font-weight: 700;
        }
        .step-arrow { font-size: 10px; }
        .step-label-text {
            font-size: 10px;
            font-weight: 700;
            margin-bottom: 6px;
        }
        .step-desc {
            color: var(--sub);
            font-size: 10px;
            line-height: 1.7;
        }

        /* Steps list */
        .steps-list-card {
            border: 1px solid var(--border);
            max-height: 280px;
            overflow-y: auto;
        }
        .steps-list-card::-webkit-scrollbar { width: 4px; }
        .steps-list-card::-webkit-scrollbar-track { background: transparent; }
        .steps-list-card::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
        .steps-list-title {
            color: var(--muted);
            font-size: 9px;
            letter-spacing: 2px;
            margin-bottom: 8px;
            font-weight: 700;
        }
        .step-item {
            display: flex;
            gap: 8px;
            align-items: flex-start;
            padding: 5px 6px;
            border-radius: 6px;
            cursor: pointer;
            border: 1px solid transparent;
            margin-bottom: 2px;
            transition: all 0.15s;
        }
        .step-item-num {
            font-size: 9px;
            font-weight: 700;
            min-width: 16px;
        }
        .step-item-label { font-size: 9px; line-height: 1.5; }
        .step-item-sub { color: var(--muted); font-size: 8px; }

        /* Dependencies grid */
        .deps-grid {
            max-width: 1200px;
            margin: 14px auto 0;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }
        .dep-card {
            background: var(--card);
            border-radius: 10px;
            padding: 10px 12px;
        }
        .dep-title { font-weight: 800; font-size: 10px; margin-bottom: 6px; }
        .dep-heading { color: var(--muted); font-size: 8px; margin-bottom: 4px; letter-spacing: 1px; }
        .dep-heading.mt { margin-top: 6px; }
        .dep-item { font-size: 9px; line-height: 1.7; }
        .dep-item.depends { color: var(--sub); }

        .hld-footer {
            text-align: center;
            margin-top: 14px;
            color: var(--muted);
            font-size: 9px;
            letter-spacing: 2px;
            padding-bottom: 20px;
        }

        @media (max-width: 900px) {
            .hld-main { flex-direction: column; }
            .right-panel { width: 100%; }
            .deps-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 500px) {
            .deps-grid { grid-template-columns: 1fr; }
            .scenario-tab { padding: 6px 12px; font-size: 10px; }
        }
    </style>
</head>
<body>
    <a href="/#projects" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Portfolio
    </a>

    <div class="hld-container">
        <div class="hld-header">
            <div class="hld-title">🏗️ DIGITAL WALLET — HLD FLOW DIAGRAM</div>
            <div class="hld-subtitle">INTERACTIVE · SELECT A SCENARIO · STEP THROUGH OR AUTOPLAY</div>
        </div>

        <div class="scenario-tabs" id="scenarioTabs"></div>

        <div class="hld-main">
            <div class="svg-wrap">
                <svg id="svgCanvas" viewBox="0 0 1000 650"></svg>
            </div>
            <div class="right-panel" id="rightPanel"></div>
        </div>

        <div class="deps-grid" id="depsGrid"></div>
        <div class="hld-footer">DIGITAL WALLET HLD FLOW · 4 SCENARIOS · 8 MICROSERVICES · CLICK ANY STEP TO JUMP</div>
    </div>

<script>
(function () {
    const C = {
        bg:"#05080f",surface:"#090d16",card:"#0d1420",border:"#162030",
        text:"#dde6f0",muted:"#3d5470",sub:"#7a9ab8",
        client:"#06b6d4",gateway:"#a855f7",user:"#3b82f6",wallet:"#22c55e",
        txn:"#f59e0b",payment:"#f97316",fraud:"#ef4444",kyc:"#ec4899",
        notif:"#8b5cf6",ledger:"#14b8a6",kafka:"#fb923c",db:"#64748b",ext:"#94a3b8",
    };

    const SCENARIOS = [
        { id:"register", label:"User Registration", icon:"👤", color:C.client },
        { id:"p2p",      label:"P2P Transfer",      icon:"💸", color:C.txn },
        { id:"topup",    label:"Wallet Top-Up",      icon:"💳", color:C.wallet },
        { id:"payment",  label:"Merchant Payment",   icon:"🏪", color:C.payment },
    ];

    const NODES = {
        mobile:  {label:"Mobile App",icon:"📱",color:C.client,x:60,y:80,group:"client"},
        web:     {label:"Web App",icon:"🌐",color:C.client,x:60,y:180,group:"client"},
        merchant:{label:"Merchant Portal",icon:"🏪",color:C.client,x:60,y:280,group:"client"},
        gateway: {label:"API Gateway",icon:"🔀",color:C.gateway,x:240,y:160,group:"gateway"},
        user:    {label:"User Service",icon:"👤",color:C.user,x:460,y:60,group:"core"},
        wallet:  {label:"Wallet Service",icon:"💼",color:C.wallet,x:460,y:180,group:"core"},
        txn:     {label:"Transaction Svc",icon:"💸",color:C.txn,x:460,y:300,group:"core"},
        payment: {label:"Payment Service",icon:"💳",color:C.payment,x:460,y:420,group:"core"},
        fraud:   {label:"Fraud Detection",icon:"🕵️",color:C.fraud,x:680,y:120,group:"core"},
        kyc:     {label:"KYC / AML",icon:"✅",color:C.kyc,x:680,y:240,group:"core"},
        notif:   {label:"Notification Svc",icon:"🔔",color:C.notif,x:680,y:360,group:"core"},
        ledger:  {label:"Ledger Service",icon:"📒",color:C.ledger,x:680,y:480,group:"core"},
        kafka:   {label:"Apache Kafka",icon:"📨",color:C.kafka,x:460,y:560,group:"infra"},
        userdb:  {label:"User DB\n(Postgres)",icon:"🐘",color:C.db,x:880,y:60,group:"data"},
        walletdb:{label:"Wallet DB\n(Postgres)",icon:"🐘",color:C.db,x:880,y:180,group:"data"},
        txndb:   {label:"Txn DB\n(Postgres)",icon:"🐘",color:C.db,x:880,y:300,group:"data"},
        redis:   {label:"Redis\n(Cache)",icon:"⚡",color:C.db,x:880,y:420,group:"data"},
        cassandra:{label:"Cassandra\n(Ledger)",icon:"💎",color:C.db,x:880,y:540,group:"data"},
        ext:     {label:"Payment Gateway\n(Stripe/Razorpay)",icon:"🔗",color:C.ext,x:240,y:460,group:"ext"},
        bankapi: {label:"Bank APIs\n(NPCI/SWIFT)",icon:"🏦",color:C.ext,x:240,y:560,group:"ext"},
    };

    const FLOWS = {
        register:{title:"User Registration Flow",color:C.client,steps:[
            {id:1,from:"mobile",to:"gateway",type:"REST",label:"POST /auth/register",color:C.client,desc:"Client sends registration payload (email, phone, password)"},
            {id:2,from:"gateway",to:"user",type:"REST",label:"Route → User Service",color:C.gateway,desc:"Gateway validates JWT format, rate-checks, routes request"},
            {id:3,from:"user",to:"userdb",type:"WRITE",label:"INSERT user (PENDING)",color:C.user,desc:"User saved with status=PENDING, password BCrypt-hashed"},
            {id:4,from:"user",to:"kafka",type:"EVENT",label:"USER_REGISTERED event",color:C.kafka,desc:"Domain event published to Kafka topic: user.events"},
            {id:5,from:"kafka",to:"notif",type:"EVENT",label:"Consume USER_REGISTERED",color:C.notif,desc:"Notification Service sends OTP SMS via Twilio"},
            {id:6,from:"kafka",to:"kyc",type:"EVENT",label:"Consume USER_REGISTERED",color:C.kyc,desc:"KYC Service initiates identity verification onboarding"},
            {id:7,from:"kafka",to:"wallet",type:"EVENT",label:"Consume USER_REGISTERED",color:C.wallet,desc:"Wallet Service auto-provisions default wallet for the user"},
            {id:8,from:"wallet",to:"walletdb",type:"WRITE",label:"CREATE wallet record",color:C.wallet,desc:"New wallet row created with zero balance, status=INACTIVE"},
            {id:9,from:"mobile",to:"gateway",type:"REST",label:"POST /auth/verify-otp",color:C.client,desc:"User submits OTP received on phone"},
            {id:10,from:"gateway",to:"user",type:"REST",label:"Route → OTP verify",color:C.gateway,desc:"OTP validated against Redis (TTL=5min)"},
            {id:11,from:"user",to:"userdb",type:"WRITE",label:"UPDATE status=ACTIVE",color:C.user,desc:"User and wallet activated; access+refresh JWT issued"},
        ]},
        p2p:{title:"P2P Transfer Flow",color:C.txn,steps:[
            {id:1,from:"mobile",to:"gateway",type:"REST",label:"POST /transactions/transfer",color:C.client,desc:"Sender submits: amount, receiver ID, optional note"},
            {id:2,from:"gateway",to:"txn",type:"REST",label:"Route → Transaction Service",color:C.gateway,desc:"JWT validated; RBAC checked; routed to Transaction Service"},
            {id:3,from:"txn",to:"user",type:"REST",label:"GET /users/{id}/status",color:C.user,desc:"Verify both sender + receiver are ACTIVE, KYC verified"},
            {id:4,from:"txn",to:"fraud",type:"REST",label:"POST /fraud/evaluate",color:C.fraud,desc:"Fraud score computed: velocity, geo, device, pattern analysis"},
            {id:5,from:"txn",to:"wallet",type:"REST",label:"GET /wallets/{id}/balance",color:C.wallet,desc:"Check sender has sufficient balance (Redis cache first)"},
            {id:6,from:"txn",to:"txndb",type:"WRITE",label:"CREATE txn (INITIATED)",color:C.txn,desc:"Transaction record persisted; Saga begins"},
            {id:7,from:"txn",to:"kafka",type:"EVENT",label:"TXN_DEBIT_CMD event",color:C.kafka,desc:"Saga Step 1: Command to debit sender wallet"},
            {id:8,from:"kafka",to:"wallet",type:"EVENT",label:"Consume TXN_DEBIT_CMD",color:C.wallet,desc:"Wallet Service debits sender; publishes WALLET_DEBITED"},
            {id:9,from:"wallet",to:"walletdb",type:"WRITE",label:"UPDATE balance (debit)",color:C.wallet,desc:"Atomic UPDATE with optimistic locking on wallet row"},
            {id:10,from:"kafka",to:"wallet",type:"EVENT",label:"TXN_CREDIT_CMD event",color:C.kafka,desc:"Saga Step 2: Command to credit receiver wallet"},
            {id:11,from:"wallet",to:"walletdb",type:"WRITE",label:"UPDATE balance (credit)",color:C.wallet,desc:"Receiver balance incremented; WALLET_CREDITED published"},
            {id:12,from:"kafka",to:"ledger",type:"EVENT",label:"Consume WALLET_CREDITED",color:C.ledger,desc:"Ledger records double-entry: DEBIT senderA / CREDIT receiverB"},
            {id:13,from:"ledger",to:"cassandra",type:"WRITE",label:"Append ledger entries",color:C.ledger,desc:"Immutable append-only entries in Cassandra"},
            {id:14,from:"kafka",to:"notif",type:"EVENT",label:"Consume TXN_COMPLETED",color:C.notif,desc:"Push + SMS notifications sent to both sender and receiver"},
            {id:15,from:"txn",to:"txndb",type:"WRITE",label:"UPDATE txn (COMPLETED)",color:C.txn,desc:"Final transaction status updated; response returned to client"},
        ]},
        topup:{title:"Wallet Top-Up Flow",color:C.wallet,steps:[
            {id:1,from:"mobile",to:"gateway",type:"REST",label:"POST /payments/topup",color:C.client,desc:"User initiates top-up with card details (tokenized)"},
            {id:2,from:"gateway",to:"payment",type:"REST",label:"Route → Payment Service",color:C.gateway,desc:"Routed to Payment Service; card data never touches other services"},
            {id:3,from:"payment",to:"fraud",type:"REST",label:"POST /fraud/evaluate",color:C.fraud,desc:"Card payment fraud check: BIN analysis, 3DS, device trust"},
            {id:4,from:"payment",to:"ext",type:"REST",label:"Charge card (Stripe API)",color:C.ext,desc:"Payment Gateway processes card charge; returns payment intent ID"},
            {id:5,from:"payment",to:"kafka",type:"EVENT",label:"PAYMENT_CAPTURED event",color:C.kafka,desc:"Kafka event with amount, userId, paymentRef published"},
            {id:6,from:"kafka",to:"wallet",type:"EVENT",label:"Consume PAYMENT_CAPTURED",color:C.wallet,desc:"Wallet Service credits user wallet with top-up amount"},
            {id:7,from:"wallet",to:"walletdb",type:"WRITE",label:"UPDATE balance (credit)",color:C.wallet,desc:"Wallet balance updated; status=ACTIVE if first load"},
            {id:8,from:"kafka",to:"ledger",type:"EVENT",label:"Consume PAYMENT_CAPTURED",color:C.ledger,desc:"Ledger records: DEBIT external / CREDIT user wallet"},
            {id:9,from:"kafka",to:"notif",type:"EVENT",label:"Consume TOPUP_SUCCESS",color:C.notif,desc:"Push notification + email receipt sent to user"},
        ]},
        payment:{title:"Merchant Payment Flow",color:C.payment,steps:[
            {id:1,from:"merchant",to:"gateway",type:"REST",label:"POST /payments/collect",color:C.client,desc:"Merchant initiates payment collection with QR/link"},
            {id:2,from:"gateway",to:"txn",type:"REST",label:"Route → Transaction Service",color:C.gateway,desc:"Merchant JWT verified; merchant account validated"},
            {id:3,from:"txn",to:"user",type:"REST",label:"Verify payer status",color:C.user,desc:"Payer user status check: ACTIVE + KYC_VERIFIED"},
            {id:4,from:"txn",to:"fraud",type:"REST",label:"Fraud evaluation",color:C.fraud,desc:"Merchant payment risk: amount, merchant category, payer history"},
            {id:5,from:"txn",to:"wallet",type:"REST",label:"Check payer balance",color:C.wallet,desc:"Sufficient wallet balance confirmed"},
            {id:6,from:"txn",to:"kafka",type:"EVENT",label:"MERCHANT_PAY_CMD",color:C.kafka,desc:"Saga: debit payer wallet, credit merchant wallet"},
            {id:7,from:"kafka",to:"wallet",type:"EVENT",label:"Debit payer wallet",color:C.wallet,desc:"Payer debited; merchant wallet credited in same saga"},
            {id:8,from:"wallet",to:"walletdb",type:"WRITE",label:"Atomic debit/credit",color:C.wallet,desc:"Both wallet updates written; optimistic locking prevents race"},
            {id:9,from:"kafka",to:"ledger",type:"EVENT",label:"Record merchant payment",color:C.ledger,desc:"Ledger: DEBIT payer / CREDIT merchant / note MDR fee"},
            {id:10,from:"payment",to:"ext",type:"REST",label:"Settlement batch (NPCI)",color:C.ext,desc:"End-of-day settlement via NPCI/SWIFT bank APIs"},
            {id:11,from:"kafka",to:"notif",type:"EVENT",label:"Payment notifications",color:C.notif,desc:"SMS/push to payer (debit) + merchant (credit) confirmation"},
        ]}
    };

    const TYPE_STYLE = {
        REST:  { color:"#3b82f6", label:"REST",  dash:"none" },
        EVENT: { color:"#f97316", label:"EVENT", dash:"6,4" },
        WRITE: { color:"#22c55e", label:"DB",    dash:"2,4" },
    };

    const NODE_W = 110, NODE_H = 52;
    const SVG_W = 1000, SVG_H = 650;

    let scenario = "register";
    let step = 0;
    let playing = false;
    let timer = null;

    function flow() { return FLOWS[scenario]; }
    function steps() { return flow().steps; }

    // SVG helper
    function svgEl(tag, attrs, children) {
        const el = document.createElementNS("http://www.w3.org/2000/svg", tag);
        if (attrs) Object.entries(attrs).forEach(([k,v]) => el.setAttribute(k, v));
        if (typeof children === "string") el.textContent = children;
        else if (Array.isArray(children)) children.forEach(c => { if (c) el.appendChild(c); });
        return el;
    }
    function htmlEl(tag, attrs, children) {
        const el = document.createElement(tag);
        if (attrs) {
            Object.entries(attrs).forEach(([k,v]) => {
                if (k === "style" && typeof v === "object") Object.assign(el.style, v);
                else if (k.startsWith("on")) el.addEventListener(k.slice(2), v);
                else el.setAttribute(k, v);
            });
        }
        if (typeof children === "string") el.innerHTML = children;
        else if (Array.isArray(children)) children.forEach(c => { if (c) { if (typeof c === "string") { const s = document.createElement("span"); s.innerHTML = c; el.appendChild(s); } else el.appendChild(c); }});
        return el;
    }

    function renderTabs() {
        const wrap = document.getElementById("scenarioTabs");
        wrap.innerHTML = "";
        SCENARIOS.forEach(s => {
            const btn = htmlEl("button", {
                class: "scenario-tab" + (scenario === s.id ? " active" : ""),
                style: scenario === s.id
                    ? { background: s.color + "22", borderColor: s.color, color: s.color, boxShadow: `0 0 14px ${s.color}33` }
                    : {},
                onclick: () => { scenario = s.id; step = 0; playing = false; clearTimeout(timer); render(); }
            }, s.icon + " " + s.label);
            wrap.appendChild(btn);
        });
    }

    function buildEdgeMaps() {
        const s = steps();
        const count = {}, idx = [], totals = {};
        s.forEach(st => {
            const key = [st.from, st.to].sort().join("-");
            count[key] = (count[key] || 0) + 1;
            idx.push(count[key] - 1);
        });
        s.forEach(st => {
            const key = [st.from, st.to].sort().join("-");
            totals[key] = (totals[key] || 0) + 1;
        });
        return { idx, totals };
    }

    function renderSVG() {
        const svg = document.getElementById("svgCanvas");
        svg.innerHTML = "";
        const s = steps();
        const f = flow();
        const activeNodes = s[step] ? new Set([s[step].from, s[step].to]) : new Set();
        const visitedNodes = new Set(s.slice(0, step + 1).flatMap(st => [st.from, st.to]));
        const { idx, totals } = buildEdgeMaps();

        // Group bands
        [
            {label:"CLIENT",x:20,w:155,color:C.client,y:20,h:400},
            {label:"API GATEWAY",x:195,w:115,color:C.gateway,y:20,h:400},
            {label:"CORE SERVICES",x:425,w:375,color:C.user,y:20,h:400},
            {label:"DATA STORES",x:848,w:140,color:C.db,y:20,h:400},
            {label:"EXTERNAL",x:195,w:115,color:C.ext,y:430,h:160},
        ].forEach(g => {
            svg.appendChild(svgEl("rect", {x:g.x,y:g.y,width:g.w,height:g.h,rx:10,fill:g.color+"06",stroke:g.color+"18","stroke-width":1}));
            svg.appendChild(svgEl("text", {x:g.x+g.w/2,y:g.y+14,"text-anchor":"middle",fill:g.color+"88","font-size":7.5,"font-family":"'JetBrains Mono', monospace","font-weight":700,"letter-spacing":2}, g.label));
        });
        // Kafka band
        svg.appendChild(svgEl("rect", {x:425,y:520,width:375,height:110,rx:10,fill:C.kafka+"08",stroke:C.kafka+"22","stroke-width":1}));
        svg.appendChild(svgEl("text", {x:612,y:536,"text-anchor":"middle",fill:C.kafka+"88","font-size":7.5,"font-family":"'JetBrains Mono', monospace","font-weight":700,"letter-spacing":2}, "KAFKA EVENT BUS"));

        // Arrows
        s.forEach((st, i) => {
            const key = [st.from, st.to].sort().join("-");
            const isActive = i === step;
            const isVisited = i < step;
            const isDimmed = step >= 0 && !isActive && !isVisited;
            renderArrow(svg, st, isActive, isDimmed, idx[i], totals[key]);
        });

        // Nodes
        Object.entries(NODES).forEach(([id, node]) => {
            const isActive = activeNodes.has(id);
            const isVisited = visitedNodes.has(id);
            const isDimmed = step >= 0 && !isActive && !isVisited;
            renderNode(svg, id, node, isActive, isVisited && !isActive, isDimmed);
        });

        // Legend
        [{type:"REST",x:30},{type:"EVENT",x:110},{type:"WRITE",x:200}].forEach(l => {
            const st = TYPE_STYLE[l.type];
            const attrs = {x1:l.x,y1:SVG_H-22,x2:l.x+28,y2:SVG_H-22,stroke:st.color,"stroke-width":2};
            if (st.dash !== "none") attrs["stroke-dasharray"] = st.dash;
            svg.appendChild(svgEl("line", attrs));
            svg.appendChild(svgEl("text", {x:l.x+34,y:SVG_H-18,fill:C.sub,"font-size":9,"font-family":"'JetBrains Mono', monospace"}, st.label));
        });
    }

    function renderNode(svg, id, node, active, highlighted, dimmed) {
        const g = svgEl("g");
        const alpha = dimmed ? 0.25 : 1;
        if (active || highlighted) {
            g.appendChild(svgEl("rect", {x:node.x-4,y:node.y-4,width:NODE_W+8,height:NODE_H+8,rx:12,fill:node.color+"22",stroke:node.color,"stroke-width":1.5,"stroke-opacity":0.5}));
        }
        g.appendChild(svgEl("rect", {
            x:node.x,y:node.y,width:NODE_W,height:NODE_H,rx:8,fill:C.card,
            stroke:active?node.color:highlighted?node.color+"88":C.border,
            "stroke-width":active?2:1,opacity:alpha
        }));
        g.appendChild(svgEl("text", {x:node.x+NODE_W/2,y:node.y+18,"text-anchor":"middle",fill:node.color,"font-size":16,opacity:alpha}, node.icon));
        node.label.split("\n").forEach((line, i) => {
            g.appendChild(svgEl("text", {
                x:node.x+NODE_W/2,y:node.y+33+i*11,"text-anchor":"middle",
                fill:active?node.color:C.sub,"font-size":8.5,
                "font-family":"'JetBrains Mono', monospace",
                "font-weight":active?700:400,opacity:alpha
            }, line));
        });
        svg.appendChild(g);
    }

    function renderArrow(svg, st, active, dimmed, index, total) {
        const fn = NODES[st.from], tn = NODES[st.to];
        const style = TYPE_STYLE[st.type];
        const fx = fn.x+NODE_W/2, fy = fn.y+NODE_H/2;
        const tx = tn.x+NODE_W/2, ty = tn.y+NODE_H/2;
        const dx = tx-fx, dy = ty-fy;
        const len = Math.sqrt(dx*dx+dy*dy);
        const ux = dx/len, uy = dy/len;
        const startX = fx+ux*(NODE_W/2+2), startY = fy+uy*(NODE_H/2+2);
        const endX = tx-ux*(NODE_W/2+6), endY = ty-uy*(NODE_H/2+6);
        const offset = (index-(total-1)/2)*14;
        const mx = (startX+endX)/2-uy*offset;
        const my = (startY+endY)/2+ux*offset;
        const alpha = dimmed?0.12:active?1:0.45;
        const col = style.color;
        const g = svgEl("g", {opacity:alpha});
        const markerId = `arrow-${st.from}-${st.to}-${index}`;
        const defs = svgEl("defs", null, [
            svgEl("marker", {id:markerId,markerWidth:6,markerHeight:6,refX:5,refY:3,orient:"auto"}, [
                svgEl("path", {d:"M0,0 L6,3 L0,6 Z",fill:col})
            ])
        ]);
        g.appendChild(defs);
        const pathAttrs = {d:`M${startX},${startY} Q${mx},${my} ${endX},${endY}`,stroke:col,"stroke-width":active?2.2:1.2,fill:"none","marker-end":`url(#${markerId})`};
        if (style.dash !== "none") pathAttrs["stroke-dasharray"] = style.dash;
        g.appendChild(svgEl("path", pathAttrs));
        if (active) {
            const t = 0.5;
            const lx = (1-t)*(1-t)*startX+2*(1-t)*t*mx+t*t*endX;
            const ly = (1-t)*(1-t)*startY+2*(1-t)*t*my+t*t*endY-6;
            g.appendChild(svgEl("rect", {x:lx-st.label.length*2.8,y:ly-8,width:st.label.length*5.6,height:13,rx:3,fill:C.bg,stroke:col,"stroke-width":0.8}));
            g.appendChild(svgEl("text", {x:lx,y:ly,"text-anchor":"middle",fill:col,"font-size":7.5,"font-family":"'JetBrains Mono', monospace","font-weight":700}, st.label));
        }
        svg.appendChild(g);
    }

    function renderPanel() {
        const panel = document.getElementById("rightPanel");
        panel.innerHTML = "";
        const f = flow();
        const s = steps();
        const cs = s[step] || null;

        // Flow title card
        const titleCard = htmlEl("div", {class:"panel-card flow-title-card",style:{borderColor:f.color+"44"}});
        titleCard.innerHTML = `
            <div class="flow-name" style="color:${f.color}">${f.title}</div>
            <div class="flow-info">${s.length} steps · Step ${step+1} of ${s.length}</div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill" style="width:${((step+1)/s.length)*100}%;background:linear-gradient(90deg,${f.color},${f.color}99)"></div>
            </div>`;
        panel.appendChild(titleCard);

        // Controls
        const ctrl = htmlEl("div", {class:"controls"});
        const resetBtn = htmlEl("button", {class:"ctrl-btn",onclick:()=>{step=0;playing=false;clearTimeout(timer);render();}}, "↺ Reset");
        const prevBtn = htmlEl("button", {class:"ctrl-btn",style:{color:step===0?C.muted:C.sub},onclick:()=>{if(step>0){step--;playing=false;clearTimeout(timer);render();}}}, "← Prev");
        if (step===0) prevBtn.disabled = true;
        const nextBtn = htmlEl("button", {class:"ctrl-btn",style:{color:step<s.length-1?f.color:C.muted,borderColor:step<s.length-1?f.color:C.border},onclick:()=>{if(step<s.length-1){step++;playing=false;clearTimeout(timer);render();}}}, "Next →");
        if (step>=s.length-1) nextBtn.disabled = true;
        ctrl.append(resetBtn, prevBtn, nextBtn);
        panel.appendChild(ctrl);

        // Play button
        const playBtn = htmlEl("button", {
            class:"play-btn",
            style:{background:playing?C.fraud+"18":f.color+"18",border:`1.5px solid ${playing?C.fraud:f.color}`,color:playing?C.fraud:f.color},
            onclick:()=>{playing=!playing;if(playing)autoPlay();render();}
        }, playing ? "⏸ PAUSE" : "▶ AUTOPLAY");
        panel.appendChild(playBtn);

        // Current step detail
        if (cs) {
            const detail = htmlEl("div", {class:"panel-card step-detail-card",style:{border:`1px solid ${cs.color}55`,boxShadow:`0 0 16px ${cs.color}18`}});
            const fromN = NODES[cs.from], toN = NODES[cs.to];
            detail.innerHTML = `
                <div class="step-badges">
                    <span class="step-type-badge" style="background:${cs.color}22;border:1px solid ${cs.color}55;color:${cs.color}">${TYPE_STYLE[cs.type].label}</span>
                    <span class="step-num">STEP ${cs.id}</span>
                </div>
                <div class="step-nodes">
                    <span class="step-node-badge" style="background:${fromN.color}22;color:${fromN.color}">${fromN.icon} ${fromN.label.split("\\n")[0]}</span>
                    <span class="step-arrow" style="color:${cs.color}">→</span>
                    <span class="step-node-badge" style="background:${toN.color}22;color:${toN.color}">${toN.icon} ${toN.label.split("\\n")[0]}</span>
                </div>
                <div class="step-label-text" style="color:${cs.color}">${cs.label}</div>
                <div class="step-desc">${cs.desc}</div>`;
            panel.appendChild(detail);
        }

        // All steps list
        const listCard = htmlEl("div", {class:"panel-card steps-list-card"});
        listCard.innerHTML = '<div class="steps-list-title">ALL STEPS</div>';
        s.forEach((st, i) => {
            const item = htmlEl("div", {
                class:"step-item",
                style: i===step ? {background:f.color+"14",borderColor:f.color+"44"} : {},
                onclick:()=>{step=i;playing=false;clearTimeout(timer);render();}
            });
            const numClr = i<step?f.color:i===step?f.color:C.muted;
            const textClr = i===step?C.text:i<step?C.sub:C.muted;
            item.innerHTML = `
                <span class="step-item-num" style="color:${numClr}">${i<step?"✓":i===step?"▶":i+1}</span>
                <div>
                    <div class="step-item-label" style="color:${textClr};font-weight:${i===step?700:400}">${st.label}</div>
                    <div class="step-item-sub">${NODES[st.from].label.split("\\n")[0]} → ${NODES[st.to].label.split("\\n")[0]}</div>
                </div>`;
            listCard.appendChild(item);
        });
        panel.appendChild(listCard);
    }

    function renderDeps() {
        const grid = document.getElementById("depsGrid");
        grid.innerHTML = "";
        [
            {svc:"User Service",color:C.user,deps:["PostgreSQL (R/W)","Redis (sessions)","Kafka (publish)"],calledBy:["API Gateway","Transaction Svc","Ledger Svc"]},
            {svc:"Wallet Service",color:C.wallet,deps:["PostgreSQL (R/W)","Redis (balance cache)","Kafka (consume+pub)"],calledBy:["Transaction Svc","Kafka events"]},
            {svc:"Transaction Svc",color:C.txn,deps:["PostgreSQL (R/W)","Kafka (publish)","User Svc REST","Wallet Svc REST","Fraud REST"],calledBy:["API Gateway"]},
            {svc:"Fraud Detection",color:C.fraud,deps:["Redis (velocity)","ML Model","Cassandra (history)"],calledBy:["Transaction Svc","Payment Svc"]},
            {svc:"Payment Service",color:C.payment,deps:["Stripe/Razorpay API","Kafka (publish)","Fraud REST"],calledBy:["API Gateway"]},
            {svc:"KYC / AML",color:C.kyc,deps:["KYC Provider API","PostgreSQL (R/W)","Kafka (consume+pub)"],calledBy:["Kafka: USER_REGISTERED"]},
            {svc:"Notification Svc",color:C.notif,deps:["Twilio (SMS)","SES (Email)","FCM (Push)"],calledBy:["Kafka: all events"]},
            {svc:"Ledger Service",color:C.ledger,deps:["Cassandra (append-only)","Kafka (consume)"],calledBy:["Kafka: wallet/payment events"]},
        ].forEach(s => {
            const card = htmlEl("div", {class:"dep-card",style:{border:`1px solid ${s.color}33`}});
            let html = `<div class="dep-title" style="color:${s.color}">${s.svc}</div>`;
            html += '<div class="dep-heading">DEPENDS ON</div>';
            s.deps.forEach(d => html += `<div class="dep-item depends">▸ ${d}</div>`);
            html += '<div class="dep-heading mt">CALLED BY</div>';
            s.calledBy.forEach(d => html += `<div class="dep-item" style="color:${s.color}cc">← ${d}</div>`);
            card.innerHTML = html;
            grid.appendChild(card);
        });
    }

    function autoPlay() {
        clearTimeout(timer);
        if (!playing) return;
        timer = setTimeout(() => {
            if (step < steps().length - 1) { step++; render(); autoPlay(); }
            else { playing = false; render(); }
        }, 1600);
    }

    function render() {
        renderTabs();
        renderSVG();
        renderPanel();
    }

    // Initial render
    render();
    renderDeps();

    // Re-render deps only on scenario change (they're static, but let's keep it simple)
    const origRender = render;
    render = function() { origRender(); };
})();
</script>
</body>
</html>
